<h1>Список постів</h1>

<%= link_to '➕ Створити пост', new_post_path, class: "btn btn-success mb-3" %>

<table class="table table-striped table-hover">
  <thead>
  <tr>
    <th>Заголовок</th>
    <th>Зміст</th>
    <th>Дії</th>
  </tr>
  </thead>

  <tbody>
  <% @posts.each do |post| %>
    <tr>
      <td><%= post.title %></td>
      <td><%= truncate(post.content, length: 100) %></td>
      <td>
        <%= link_to 'Переглянути', post, class: "btn btn-info btn-sm" %>
        <%= link_to 'Редагувати', edit_post_path(post), class: "btn btn-warning btn-sm" %>
        <%= link_to 'Видалити', post, method: :delete, data: { confirm: 'Ви впевнені?' }, class: "btn btn-danger btn-sm" %>
      </td>
    </tr>
  <% end %>
  </tbody>
</table>
